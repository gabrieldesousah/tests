{
  "manifest_version": 3,
  "name": "BG/Text Color Inspector",
  "version": "1.0.0",
  "description": "Exibe classes de cor bg-* e text-* ao passar o mouse nos elementos da página.",
  "permissions": ["activeTab"],
  "action": {
    "default_title": "Ativar inspetor de cores (bg-*/text-*)",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
