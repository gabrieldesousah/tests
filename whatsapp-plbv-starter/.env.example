# Meta app (developers.facebook.com)
META_APP_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v21.0

# Embedded Signup: Configuration ID from App Dashboard > WhatsApp > Quickstart / Embedded signup
META_EMBEDDED_SIGNUP_CONFIG_ID=

# Solution Partner business portfolio ID (yours, not the client's)
PARTNER_BUSINESS_PORTFOLIO_ID=

# System User token: admin on partner portfolio, business_management granted to the app
PARTNER_SYSTEM_USER_ACCESS_TOKEN=

# Webhook verification (configure in App Dashboard > Webhooks)
WEBHOOK_VERIFY_TOKEN=

# Public base URL of this server (e.g. https://abc.ngrok.io) for OAuth redirect if you use redirect flows
PUBLIC_BASE_URL=http://localhost:3000

# If troca de code falhar, defina o redirect_uri exatamente como no painel do app (opcional)
# META_OAUTH_REDIRECT_URI=https://your-domain/oauth/callback
